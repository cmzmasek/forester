<?xml version="1.0" encoding="ISO-8859-1"?>
<project name="FORESTER" basedir="." default="all">

    <property name="src.dir" value="src"/>
    <property name="classes.dir" value="classes"/>
    <property name="jars.dir" value="resources"/>
    <property name="openpdfjar" value="${jars.dir}/openpdf-1.3.35.jar"/>
    <property name="commonscodecjar" value="${jars.dir}/commons-codec-1.5.jar"/>
    <property name="openchartjar" value="${jars.dir}/openchart.jar"/>
    <property name="flatlafjar" value="${jars.dir}/flatlaf-3.7.1.jar"/>
    <property name="vectorgraphics2djar" value="${jars.dir}/VectorGraphics2D-0.13.jar"/>
    <property name="forester_jar" value="forester.jar"/>

    <target name="clean" description="Delete all generated files">
        <delete dir="${classes.dir}" failonerror="false"/>
        <delete file="${forester_jar}"/>
    </target>

    <target name="copy_resources" description="Copies resources">
        <mkdir dir="${classes.dir}/resources"/>
        <copy verbose="true"
              file="../resources/phyloxml_schema/1.20/phyloxml.xsd"
              todir="${classes.dir}/resources"/>
        <mkdir dir="${classes.dir}/resources/fonts"/>
        <copy todir="${classes.dir}/resources/fonts">
            <fileset dir="../resources/fonts" includes="*.ttf,LICENSE*,*.md,*.txt"/>
        </copy>
    </target>

    <target name="compile" description="Compiles the Task" depends="clean,copy_resources">
        <mkdir dir="${classes.dir}"/>
        <javac release="21" debug="true" debuglevel="lines,source" srcdir="${src.dir}"
               destdir="${classes.dir}" optimize="on" verbose="false"
               includeantruntime="false"
               classpath="${openpdfjar};${commonscodecjar};${openchartjar};${flatlafjar};${vectorgraphics2djar}">
            <compilerarg value="-Xlint:deprecation"/>
            <compilerarg value="-Xlint:unchecked"/>
        </javac>
    </target>

    <target name="jar" description="JARs the classes files" depends="compile,copy_resources">
        <unjar src="${openpdfjar}" dest="${classes.dir}">
            <patternset>
                <include name="**/*.class"/>
                <include name="**/*.afm"/>
                <include name="**/*.cmap"/>
                <include name="**/*.properties"/>
                <include name="**/*.txt"/>
                <exclude name="module-info.class"/>
            </patternset>
        </unjar>
        <unjar src="${commonscodecjar}" dest="${classes.dir}">
            <patternset>
                <include name="**/*.class"/>
                <exclude name="**/*Test*.class"/>
            </patternset>
        </unjar>
        <unjar src="${openchartjar}" dest="${classes.dir}">
            <patternset>
                <include name="**/*.class"/>
                <exclude name="**/*Test*.class"/>
            </patternset>
        </unjar>
        <unjar src="${flatlafjar}" dest="${classes.dir}">
            <patternset>
                <include name="**/*.class"/>
                <include name="**/*.properties"/>
                <include name="com/formdev/flatlaf/natives/**"/>
                <exclude name="module-info.class"/>
                <!-- NOTE: no "*Test*" exclude here: FlatLaf ships no JUnit classes, and that pattern
                     would strip the legitimate class FlatTitlePane$TitleBarCaptionHitTest. -->
            </patternset>
        </unjar>
        <unjar src="${vectorgraphics2djar}" dest="${classes.dir}">
            <patternset>
                <include name="**/*.class"/>
            </patternset>
        </unjar>
        <!-- keep test-only classes out of the shipped jar; spelled out by name rather than a
             *Test* wildcard, which would also strip FlatLaf's legitimate ...$TitleBarCaptionHitTest -->
        <jar level="9" destfile="${forester_jar}" basedir="${classes.dir}" excludes="**/Test.class,**/PropertyColorSchemeTest*.class,**/TreePanelUtilTest*.class,**/AptxUtilTest*.class,**/ConfigurationTest*.class,**/SettingsDialogTest*.class,**/TabContextMenuTest*.class,**/SubSuperTreeButtonsTest*.class,**/MenuTooltipsTest*.class,**/ConfidenceRenderTest*.class,**/MadSupportClearedTest*.class,**/LegendDragTest*.class,**/ConfidenceLabelTest*.class,**/PropertyLegendBarTest*.class,**/LegendPlacementTest*.class,**/ConnectorColorTest*.class,**/FoundBranchExportTest*.class,**/SequenceAndTaxonomyDataObtainerTest*.class,**/LabelDataExtractorTest*.class,**/VectorGraphicsExporterTest*.class,**/LabelAdvanceWidthTest*.class,**/NodeSupportSymbolTest*.class,**/RankLegendTest*.class,**/InternalLabelPlacementTest*.class,**/ItalicScientificNamesTest*.class,**/ExportResolutionTest*.class,**/CollapseMenuFontTest*.class,**/DisplayDataCheckboxTest*.class,**/NcbiTaxonomyLineageServiceTest*.class,**/UniProtKbClientTest*.class,**/AccessionAwareLineageServiceTest*.class,**/NcbiSequenceClientTest*.class,**/SequenceTaxonomyResolverTest*.class,**/TaxonomyDiskCacheTest*.class,**/FontResourcesTest*.class,**/FontSizeControlTest*.class,**/TreeColorSchemeTest*.class" duplicate="fail"
             index="true">
            <manifest>
                <attribute name="Main-Class" value="org.forester.archaeopteryx.Archaeopteryx"/>
            </manifest>
        </jar>
    </target>

    <target name="all" description="" depends="jar">
    </target>


</project>
